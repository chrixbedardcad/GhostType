<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow posting synthetic keyboard/mouse events (CGEventPost). -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Allow outbound network connections (LLM API calls). -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Hardened runtime: allow unsigned executable memory (llama.cpp JIT/CGo). -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Hardened runtime: disable library validation (CGo shared libs). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
